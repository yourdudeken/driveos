# ── Client-side (safe to expose — injected into the browser bundle) ──
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# ── Server-side only (NEVER prefix with VITE_) ──
# Used exclusively by the /api/ai Vercel Function.
# Set this in Vercel's dashboard under Settings → Environment Variables.
# Do NOT put it in .env for production — it must not reach the client bundle.
OPENROUTER_API_KEY=sk-your-openrouter-api-key
